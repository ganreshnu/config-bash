Color() {
	local color="$1"; shift
	printf "$(tput setaf "$color")%s$(tput sgr0)" "$*"
}
Italics() {
	printf "$(tput sitm)%s$(tput ritm)" "$*"
}
Style() {
	local style="$1"; shift
	printf "$(tput "$style")%s$(tput sgr0)" "$*"
}
#
# simple argument parser.
# Usage: ExpectArg val cnt
# the first 2 parameters are value and count followed by the program arguments.
ExpectArg() {
	local -n v="$1"; shift
	local -n c="$1"; shift
	local name="${1%%=*}"
	c=0
	if [[ "$1" == "${name}" ]]; then
		(( $# < 2 )) && { >&2 printf "${ tput setaf 1; }%s:${ tput sgr0; } ${ tput bold; }${ tput sitm; }%s${ tput ritm; }${ tput sgr0; } expects a value.\n" "${BASH_SOURCE[1]}" "$1"; } && return 1
		v="$2"; c=1
		return 0
	fi
	v="${1#*=}"
}
PROMPT_COMMAND=__prompt_command
__prompt_command() {
	local exitCode="$?"


	__status() {
		if git rev-parse 2>/dev/null; then
			local branch="$(git branch --show-current)"
			printf ' on %s' "$(__color 4 "$branch")"
		fi
	}
	# PS1_GIT="$(__status)"

	local color=2
	if [[ $exitCode != 0 ]]; then
		color=1
	fi
	# PS1_RESULT="$(__color "$color" '\$')"
	PS1_RESULT="$color"

	return "$exitCode"
}

PS1='[\[$(tput setaf 8)\]\h\[$(tput sgr0)\] \[$(tput setaf 3)\]\W\[$(tput sgr0)\]]\[$(tput setaf $PS1_RESULT)\]$\[$(tput sgr0)\] '


# include aliases
. "${XDG_CONFIG_HOME:-$HOME/.config}"/bash/aliases

